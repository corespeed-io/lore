GBRAIN_MCP_URL=https://your-gbrain.example/mcp
GBRAIN_TOKEN=gbrain_at_xxx        # server-only, never shipped to the browser
# Preferred over GBRAIN_TOKEN: an OAuth2 client_credentials client (use a
# READ-ONLY one). The server mints short-lived access tokens from these, so a
# leak can't write to the brain. Falls back to GBRAIN_TOKEN when unset.
# GBRAIN_CLIENT_ID=gbrain_cl_xxx
# GBRAIN_CLIENT_SECRET=xxx
# GBRAIN_TOKEN_URL=https://your-gbrain.example/token   # optional; default: <MCP origin>/token
# GBRAIN_TOKEN_AUTH_METHOD=post   # post (default; creds in body) | basic (Authorization header)
# GBRAIN_SCOPE=read               # optional; requested OAuth scope
APP_TITLE=gbrain
# APP_SUBTITLE=A searchable knowledge graph of your team's memory.   # hero subtitle
# SEED_QUERIES=overview getting started || architecture design decisions || people team roles || projects products
# BRAND_COLORS={"person":"#7F77DD","company":"#D85A30","product":"#1D9E75","concept":"#888780"}
# --- Auth ---
# Defaults to LOCAL DEV with auth OFF so `npm run dev` works out of the box.
# NEVER deploy with ALLOW_INSECURE=1 — it serves your private brain to anyone.
# For any deployment, comment the two lines below out and pick a mode further down.
AUTH_MODE=none
ALLOW_INSECURE=1
# Production — pick ONE (and remove the AUTH_MODE=none / ALLOW_INSECURE lines above):
#   proxy: Cloudflare Access, JWT-verified (a proxy deploy missing ACCESS_* fails closed)
# AUTH_MODE=proxy
# ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com   # your Access team domain
# ACCESS_AUD=...                                     # the Access application AUD tag
#   password: HTTP Basic
# AUTH_MODE=password
# UI_PASSWORD=changeme
