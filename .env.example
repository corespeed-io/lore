GBRAIN_MCP_URL=https://your-gbrain.example/mcp
GBRAIN_TOKEN=gbrain_at_xxx        # server-only, never shipped to the browser
# Preferred over GBRAIN_TOKEN: an OAuth2 client_credentials client (use a
# READ-ONLY one). The server mints short-lived access tokens from these, so a
# leak can't write to the brain. Falls back to GBRAIN_TOKEN when unset.
# GBRAIN_CLIENT_ID=gbrain_cl_xxx
# GBRAIN_CLIENT_SECRET=xxx
# GBRAIN_TOKEN_URL=https://your-gbrain.example/token   # optional; default: <MCP origin>/token
APP_TITLE=gbrain
# APP_SUBTITLE=A searchable knowledge graph of your team's memory.   # hero subtitle
# SEED_QUERIES=CoreSpeed HaaS founders team product strategy moat ICP || Sarea connectors gateway billing customers interviews open risks || competitors Composio SupaBird Viktor GTM mentor playbook voice
# BRAND_COLORS={"person":"#7F77DD","company":"#D85A30","product":"#1D9E75","concept":"#888780"}
# Auth: "proxy" (Cloudflare Access, JWT-verified) or "password" (HTTP Basic).
# "none" disables auth and is ONLY honored when ALLOW_INSECURE=1 is also set —
# never deploy open. A proxy deploy missing ACCESS_AUD/ACCESS_TEAM_DOMAIN fails closed.
AUTH_MODE=proxy
# ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com   # when AUTH_MODE=proxy
# ACCESS_AUD=...                                     # the Access application AUD tag
# UI_PASSWORD=changeme            # when AUTH_MODE=password
# --- local dev without auth (insecure, never in production) ---
# AUTH_MODE=none
# ALLOW_INSECURE=1
