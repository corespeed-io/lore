  "description": "CoreSpeed's open-source web UI for browsing a gbrain knowledge graph.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "homepage": "https://github.com/corespeed-io/lore#readme",
